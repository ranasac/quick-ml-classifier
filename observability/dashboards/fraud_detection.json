{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "Fraud Detection – ML Inference Dashboard",
  "uid": "fraud-ml-dashboard",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"fraud-classifier\"}[1m])",
          "legendFormat": "req/s",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ]
    },
    {
      "id": 2,
      "title": "Prediction Latency p99 (s)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ]
    },
    {
      "id": 3,
      "title": "Fraud Predictions / min",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "rate(fraud_predictions_total{predicted_label=\"fraud\"}[1m]) * 60",
          "legendFormat": "fraud/min",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ]
    },
    {
      "id": 4,
      "title": "Model Version",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [
        {
          "expr": "model_version_info",
          "legendFormat": "{{version}}",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ]
    },
    {
      "id": 5,
      "title": "Fraud vs Non-Fraud Predictions Over Time",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {
          "expr": "rate(fraud_predictions_total[1m])",
          "legendFormat": "{{predicted_label}}",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ]
    },
    {
      "id": 6,
      "title": "Prediction Latency Distribution",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
    },
    {
      "id": 7,
      "title": "Kafka Messages (produced vs consumed)",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 12},
      "targets": [
        {
          "expr": "rate(kafka_messages_total[1m])",
          "legendFormat": "{{direction}} – {{topic}}",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ]
    },
    {
      "id": 8,
      "title": "Ingestion Records by Layer",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 12},
      "targets": [
        {
          "expr": "rate(ingestion_records_total[1m])",
          "legendFormat": "{{layer}}",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ]
    }
  ]
}
